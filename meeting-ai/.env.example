# 請複製此檔案為 .env 並填入實際值
# copy .env.example .env

# AI 分析間隔（秒），預設 60 秒
ANALYZE_INTERVAL=60

# Flask 伺服器設定
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# 音訊裝置編號（選填，不填則啟動時互動選擇）
# AUDIO_DEVICE_INDEX=

# Whisper 模型大小：tiny / base / small / medium / large-v2
WHISPER_MODEL=medium

# 音訊塊長度（秒）
CHUNK_SECONDS=5
